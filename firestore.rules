rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // 1. Global safety net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Global helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Schema validations
    function isValidUser(data, userId) {
      return data.keys().hasAll(['uid', 'email', 'createdAt'])
        && data.keys().size() == 3
        && data.uid == userId
        && data.uid == request.auth.uid
        && data.email is string
        && data.email.size() <= 256;
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['title', 'content', 'tags', 'createdAt', 'updatedAt', 'ownerId'])
        && (data.keys().size() == 6 || (data.keys().size() == 7 && 'isFavorite' in data))
        && data.title is string
        && data.title.size() <= 150
        && data.content is string
        && data.content.size() <= 100000
        && data.tags is list
        && data.tags.size() <= 10
        && (data.tags.size() == 0 || data.tags[0] is string)
        && data.ownerId == request.auth.uid
        && (!('isFavorite' in data) || data.isFavorite is bool);
    }

    // Rules for Users
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming(), userId) && incoming().createdAt == request.time;
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming(), userId) && incoming().createdAt == existing().createdAt;
      allow delete: if false; // Profiles are permanent
    }

    // Rules for User's Documents
    match /users/{userId}/documents/{documentId} {
      // Secure list and get queries
      allow read: if isOwner(userId);
      
      allow create: if isOwner(userId) 
        && isValidId(documentId) 
        && isValidDocument(incoming()) 
        && incoming().createdAt == request.time 
        && incoming().updatedAt == request.time;

      allow update: if isOwner(userId) 
        && isValidId(documentId) 
        && isValidDocument(incoming()) 
        && incoming().createdAt == existing().createdAt 
        && incoming().ownerId == existing().ownerId
        && incoming().updatedAt == request.time
        && incoming().diff(existing()).affectedKeys().hasOnly(['title', 'content', 'tags', 'isFavorite', 'updatedAt']);

      allow delete: if isOwner(userId) && isValidId(documentId);
    }
  }
}
